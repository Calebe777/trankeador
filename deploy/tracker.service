[Unit]
Description=gunicorn daemon para o Trankeador
Requires=tracker.socket
After=network.target

[Service]
User=root
Group=www-data
WorkingDirectory=/var/www/Trankeador_Definitivo
ExecStart=/var/www/Trankeador_Definitivo/venv/bin/gunicorn \
          --access-logfile - \
          --workers 3 \
          --bind unix:/run/tracker.sock \
          tracker.wsgi:application

[Install]
WantedBy=multi-user.target
