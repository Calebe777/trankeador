server {
    listen 80;
    server_name go.acadiprev.com.br;

    location = /favicon.ico { access_log off; log_not_found off; }
    
    location /static/ {
        root /var/www/Trankeador_Definitivo;
    }

    location / {
        include proxy_params;
        proxy_pass http://unix:/run/tracker.sock;
    }
}
